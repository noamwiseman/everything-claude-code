{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run_with_flags.py\" \"pre:governance-capture\" \"scripts/hooks/governance_capture.py\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "description": "Capture governance events (secrets, policy violations, approval requests). Enable with ECC_GOVERNANCE_CAPTURE=1"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run_with_flags.py\" \"post:governance-capture\" \"scripts/hooks/governance_capture.py\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "description": "Capture governance events from tool outputs. Enable with ECC_GOVERNANCE_CAPTURE=1"
      }
    ]
  }
}
